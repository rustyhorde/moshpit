# ~/.config/moshpit/moshpit.toml
# moshpit client configuration file
#
# Configuration is loaded in this order (highest priority first):
#   1. Environment variables with the MOSHPIT_ prefix (e.g. MOSHPIT_SERVER_PORT=40404)
#   2. Command-line flags
#   3. This config file

# ── Server connection ─────────────────────────────────────────────────────────
# TCP port that the moshpits server is listening on.
server_port = 40404

# IP address (or user@address) of the server to connect to.
# This can be overridden with the positional argument on the command line.
server_destination = "192.168.1.10"

# ── Reconnection ──────────────────────────────────────────────────────────────
# Maximum back-off interval between automatic reconnect attempts (seconds).
# Clamped to the range [2, 86400].  Default: 3600 (1 hour).
max_reconnect_backoff_secs = 3600

# ── Force-quit key ────────────────────────────────────────────────────────────
# Prefix key pressed (then followed by ".") to disconnect and quit.  Written as
# "ctrl-<key>"; must resolve to a control key, e.g. "ctrl-^" (default), "ctrl-a",
# or "ctrl-]".  The trailing "." confirm key is fixed.
# escape_key = "ctrl-^"

# ── Key files ─────────────────────────────────────────────────────────────────
# Defaults to ~/.mp/id_x25519 and ~/.mp/id_x25519.pub when not set (for the
# default x25519 key type). The filename reflects the --key-type used at
# generation time (e.g. id_p384, id_ml_dsa_65).
# private_key_path = "/home/alice/.mp/id_x25519"
# public_key_path  = "/home/alice/.mp/id_x25519.pub"

# ── Local echo prediction ─────────────────────────────────────────────────────
# Control client-side keystroke prediction: adaptive (default), always, or never.
# Adaptive enables prediction on high-latency connections; 'never' disables it.
predict = "adaptive"

# ── NAT traversal (optional) ──────────────────────────────────────────────────
# Send warmup keepalives before UDP session starts to establish NAT bindings.
# Only useful on NAT paths; adds one round-trip of startup latency.
# nat_warmup = false
# nat_warmup_count = 3  # Number of keepalive frames to send (default: 3)

# ── UDP diff transport mode ───────────────────────────────────────────────────
# reliable   (default): NAK-based selective retransmission; best for low-loss networks.
# datagram:             Fire-and-forget diffs; server sends periodic full-screen snapshots.
#                       Eliminates head-of-line blocking on flaky or high-loss connections.
# statesync:            Mosh-style ack-based diffs; each packet is self-contained.
#                       No NAKs, no reorder buffer; best for moderate-loss, low-bandwidth links.
# diff_mode = "reliable"

# ── Environment & PATH passthrough ────────────────────────────────────────────
# Environment variable name patterns to send to the server via ClientEnv.
# Supports exact names ("LANG") and suffix wildcards ("LC_*").
# The server's accept_env list gates which variables are actually applied.
# HOME, USER, LOGNAME, SHELL, TERM, and PATH are always server-authoritative
# and cannot be overridden via this list even if matched here.
# Default: ["LANG", "LC_*", "TZ"]
send_env = ["LANG", "LC_*", "TZ"]

# Additional directories to prepend to the server's PATH (in order).
# Ignored if the server has path_locked = true.
# Default: []
# send_path = ["/home/alice/.cargo/bin", "/home/alice/.local/bin"]

# ── Algorithm preferences (optional) ─────────────────────────────────────────
# Override the negotiated algorithms for key exchange, encryption, MAC, and KDF.
# Lists are ordered by preference; the first mutually supported algorithm wins.
# Omit any category to use the built-in defaults.
# NOTE: this section must stay below all bare keys above — TOML table headers
# ([preferred_algorithms]) absorb all following keys until the next header.
#
# [preferred_algorithms]
# kex  = ["x25519-sha256"]      # also: ml-kem-768-sha256, ml-kem-512-sha256,
#                               #       ml-kem-1024-sha256, p384-sha384, p256-sha256
# aead = ["aes256-gcm-siv"]     # also: aes256-gcm, chacha20-poly1305, aes128-gcm-siv
# mac  = ["hmac-sha512"]        # also: hmac-sha256
# kdf  = ["hkdf-sha256"]        # also: hkdf-sha384, hkdf-sha512

# ── Tracing (log output) ──────────────────────────────────────────────────────
# mp never writes to stdout (doing so would corrupt the terminal session).
# All log output goes exclusively to the file layer below.
# -v / -vv CLI flags have no effect on the file log level; set verbose here.
# Default log file: ~/.local/share/moshpit/logs/moshpit.log
[tracing.file]
quiet   = 0
verbose = 0

[tracing.file.layer]
with_target       = false
with_thread_ids   = false
with_thread_names = false
with_line_number  = false
with_level        = true
# directives = "moshpit=debug"
