# ~/.config/moshpit/moshpit.toml
# moshpit client configuration file
#
# Configuration is loaded in this order (highest priority first):
#   1. Environment variables with the MOSHPIT_ prefix (e.g. MOSHPIT_SERVER_PORT=40404)
#   2. Command-line flags
#   3. This config file

# ── Logging ───────────────────────────────────────────────────────────────────
# Each increment of verbose adds one level of detail, each increment of quiet
# removes one level.  The effective log level for the tracing file is:
#   0 quiet  + 0 verbose -> INFO
#   0 quiet  + 1 verbose -> DEBUG
#   0 quiet  + 2 verbose -> TRACE
#   1 quiet  + 0 verbose -> WARN
#   2 quiet  + 0 verbose -> ERROR
verbose = 0
quiet   = 0

# ── Server connection ─────────────────────────────────────────────────────────
# TCP port that the moshpits server is listening on.
server_port = 40404

# IP address (or user@address) of the server to connect to.
# This can be overridden with the positional argument on the command line.
server_destination = "192.168.1.10"

# ── Reconnection ──────────────────────────────────────────────────────────────
# Maximum back-off interval between automatic reconnect attempts (seconds).
# Clamped to the range [2, 86400].  Default: 3600 (1 hour).
max_reconnect_backoff_secs = 3600

# ── Key files ─────────────────────────────────────────────────────────────────
# Defaults to ~/.mp/id_ed25519 and ~/.mp/id_ed25519.pub when not set.
# private_key_path = "/home/alice/.mp/id_ed25519"
# public_key_path  = "/home/alice/.mp/id_ed25519.pub"

# ── Tracing (log output) ──────────────────────────────────────────────────────
# stdout layer — controls log line formatting when --enable-std-output is active
# (not applicable to mp, but kept for consistency with moshpits).
[tracing.stdout]
with_target       = false  # include the Rust module path in each log line
with_thread_ids   = false  # include the thread ID
with_thread_names = false  # include the thread name
with_line_number  = false  # include the source file line number
with_level        = true   # include the log level (ERROR, WARN, INFO, …)
# directives = "moshpit=debug,libmoshpit=info"  # optional tracing filter override

# file layer — controls the format and level written to the persistent log file.
# Default log file: ~/.config/moshpit/logs/moshpit.log
[tracing.file]
quiet   = 0
verbose = 0

[tracing.file.layer]
with_target       = false
with_thread_ids   = false
with_thread_names = false
with_line_number  = false
with_level        = true
# directives = "moshpit=debug"
