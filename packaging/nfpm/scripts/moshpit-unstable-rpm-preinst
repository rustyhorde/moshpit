#!/bin/sh
set -e

# $1 == 1: fresh install (including when replacing an obsoleted package)
# $1 == 2: upgrade of moshpit-unstable itself
case "$1" in
    1)
        if rpm -q moshpit 2>/dev/null | grep -qv 'not installed'; then
            echo ""
            echo "  ── moshpit-unstable: replacing stable installation ───────────────────────"
            echo ""
            echo "  moshpit (stable) is currently installed and will be replaced"
            echo "  by moshpit-unstable (post-quantum build)."
            echo ""
            echo "  ─────────────────────────────────────────────────────────────────────────"
            echo ""
        fi
        ;;
esac
