#!/bin/sh
set -e

case "$1" in
    install|upgrade)
        if dpkg-query -W -f='${Status}' moshpit-keygen 2>/dev/null \
            | grep -q 'install ok installed'; then
            echo ""
            echo "  ── moshpit-keygen-unstable: replacing stable installation ────────────────"
            echo ""
            echo "  moshpit-keygen (stable) is currently installed and will be replaced"
            echo "  by moshpit-keygen-unstable (post-quantum build)."
            echo ""
            echo "  ─────────────────────────────────────────────────────────────────────────"
            echo ""
        fi
        ;;
esac
